# =================================
# ReliefLink Environment Configuration
# =================================

# Environment
NODE_ENV=development

# =================================
# Service Ports
# =================================
API_GATEWAY_PORT=3005
CONFIG_SERVICE_PORT=3006

# =================================
# Database Configuration
# =================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/relieflink?schema=public
AUTH_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/relieflink?schema=auth_service
REQUEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/relieflink?schema=request_service
VOLUNTEER_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/relieflink?schema=volunteer_service
NOTIFICATION_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/relieflink?schema=notification_service

# =================================
# Redis Configuration
# =================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=  # Uncomment and set for production

# =================================
# JWT Configuration
# =================================
# IMPORTANT: Change this in production!
JWT_SECRET=dev-super-secret-change-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# =================================
# Service URLs (Internal)
# =================================
AUTH_SERVICE_URL=http://localhost:3001
REQUEST_SERVICE_URL=http://localhost:3002
VOLUNTEER_SERVICE_URL=http://localhost:3003
NOTIFICATION_SERVICE_URL=http://localhost:3004
CONFIG_SERVICE_URL=http://localhost:3006
API_GATEWAY_URL=http://localhost:3005

# =================================
# Service URLs (Public - for Frontend)
# =================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:3005
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:3001
NEXT_PUBLIC_REQUEST_SERVICE_URL=http://localhost:3002
NEXT_PUBLIC_VOLUNTEER_SERVICE_URL=http://localhost:3003
NEXT_PUBLIC_NOTIFICATION_SERVICE_URL=http://localhost:3004

# =================================
# Rate Limiting
# =================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =================================
# Logging
# =================================
LOG_LEVEL=info

# =================================
# Config Service Token (Internal API)
# =================================
CONFIG_SERVICE_TOKEN=

# =================================
# Email Configuration (Optional)
# =================================
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@relieflink.local

# =================================
# SMS Configuration (Optional)
# =================================
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
