{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "ReliefLink: Install Dependencies",
            "type": "shell",
            "command": "pnpm install",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "ReliefLink: Create .env From Example",
            "type": "shell",
            "command": "zsh",
            "args": [
                "-lc",
                "[ -f .env ] || cp .env.example .env"
            ],
            "problemMatcher": []
        },
        {
            "label": "ReliefLink: Prisma Generate (All Services)",
            "type": "shell",
            "command": "zsh",
            "args": [
                "-lc",
                "set -a && [ -f .env ] && source .env && set +a && pnpm db:generate"
            ],
            "problemMatcher": []
        },
        {
            "label": "ReliefLink: Prisma Push (All Services)",
            "type": "shell",
            "command": "zsh",
            "args": [
                "-lc",
                "set -a && [ -f .env ] && source .env && set +a && pnpm db:push"
            ],
            "problemMatcher": []
        },
        {
            "label": "ReliefLink: Prisma Migrate (All Services)",
            "type": "shell",
            "command": "zsh",
            "args": [
                "-lc",
                "set -a && [ -f .env ] && source .env && set +a && pnpm db:migrate"
            ],
            "problemMatcher": []
        },
        {
            "label": "ReliefLink: Build All",
            "type": "shell",
            "command": "pnpm build",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "ReliefLink: Run Backend Services (No Docker)",
            "type": "shell",
            "command": "zsh",
            "args": [
                "-lc",
                "set -a && [ -f .env ] && source .env && set +a && pnpm dev:services"
            ],
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "ReliefLink: Run Frontend (No Docker)",
            "type": "shell",
            "command": "zsh",
            "args": [
                "-lc",
                "set -a && [ -f .env ] && source .env && set +a && pnpm dev:web"
            ],
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "ReliefLink: Run Frontend + Backend (No Docker)",
            "dependsOrder": "parallel",
            "dependsOn": [
                "ReliefLink: Run Backend Services (No Docker)",
                "ReliefLink: Run Frontend (No Docker)"
            ],
            "problemMatcher": []
        },
        {
            "label": "ReliefLink: Health Check APIs",
            "type": "shell",
            "command": "zsh",
            "args": [
                "-lc",
                "curl -s http://localhost:3006/health && echo && curl -s http://localhost:3005/health && echo && curl -s http://localhost:3001/health && echo && curl -s http://localhost:3002/health && echo && curl -s http://localhost:3003/health && echo && curl -s http://localhost:3004/health && echo"
            ],
            "problemMatcher": []
        },
        {
            "label": "ReliefLink: Setup (No Docker)",
            "dependsOrder": "sequence",
            "dependsOn": [
                "ReliefLink: Create .env From Example",
                "ReliefLink: Install Dependencies",
                "ReliefLink: Prisma Generate (All Services)",
                "ReliefLink: Prisma Push (All Services)",
                "ReliefLink: Build All"
            ],
            "problemMatcher": []
        }
    ]
}
