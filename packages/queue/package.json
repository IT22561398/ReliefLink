{
  "name": "@relieflink/queue",
  "version": "1.0.0",
  "description": "BullMQ job queue for ReliefLink services",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm",
    "dev": "tsup src/index.ts --format cjs,esm --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bullmq": "^5.7.0",
    "ioredis": "^5.3.6"
  },
  "devDependencies": {
    "@relieflink/types": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "rimraf": "^5.0.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}
