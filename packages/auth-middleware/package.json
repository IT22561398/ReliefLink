{
  "name": "@relieflink/auth-middleware",
  "version": "1.0.0",
  "description": "Shared authentication middleware for ReliefLink services",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "@relieflink/types": "workspace:*",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.0",
    "express": "^4.18.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "rimraf": "^5.0.0"
  },
  "peerDependencies": {
    "express": "^4.18.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}
