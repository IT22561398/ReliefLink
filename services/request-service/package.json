{
  "name": "@relieflink/request-service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema=prisma/schema.prisma",
    "db:push": "prisma db push --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@relieflink/auth-middleware": "workspace:*",
    "@relieflink/config": "workspace:*",
    "@relieflink/logger": "workspace:*",
    "@relieflink/queue": "workspace:*",
    "@relieflink/types": "workspace:*",
    "@relieflink/utils": "workspace:*",
    "@relieflink/validators": "workspace:*",
    "bullmq": "^5.7.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "ioredis": "^5.3.6",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.9",
    "@types/pg": "^8.11.0",
    "@types/swagger-ui-express": "^4.1.6",
    "prisma": "^7.0.0",
    "rimraf": "^5.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^1.2.0"
  }
}
