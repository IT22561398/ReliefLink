generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth_service"]
}

enum Role {
  requester
  volunteer
  coordinator
  admin

  @@schema("auth_service")
}

model User {
  id           String   @id @default(uuid())
  fullName     String
  email        String   @unique
  phone        String
  passwordHash String
  role         Role     @default(requester)
  status       String?  @default("active")
  district     String
  city         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@schema("auth_service")
}
